# LangGraph agent server the Gradio chat UI (src/UI/agent_ui.py) connects to.
# Local dev: http://localhost:2024 (uv run langgraph dev, no auth needed)
# Production: your deployed LangSmith/LangGraph Platform URL
LANGGRAPH_CLIENT_URL=http://localhost:2024
# API key for the deployed LangGraph server. Leave empty for local dev.
LANGGRAPH_CLIENT_API=

# LangSmith tracing (optional locally, required once deployed via LangGraph Platform)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=

# Anthropic Claude -- used for query generation, the RAG agent, and answer generation
ANTHROPIC_API_KEY=
CHAT_MODEL_ID=claude-haiku-4-5-20251001

# HuggingFace -- embedding model id (must be a real HF model path, e.g. BAAI/bge-m3)
# and the token used to call HuggingFace's router feature-extraction endpoint
EMBEDDING_MODEL_ID=BAAI/bge-m3
HF_TOKEN=

# Chroma Cloud connection
CHROMA_API_KEY=
CHROMA_TENANT_ID=
CHROMA_DB_NAME=

# Optional but recommended -- avoids 429s on Semantic Scholar's public endpoint
SEMANTIC_SCHOLAR_API_KEY=

# Optional, defaults shown
# LOG_LEVEL=INFO
# EVAL_CHAT_MODEL_ID=claude-haiku-4-5-20251001
